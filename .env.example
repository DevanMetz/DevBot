# DevBot configuration — copy this file to ".env" and fill in your values.
#   cp .env.example .env        (bash)
#   Copy-Item .env.example .env (PowerShell)
#
# Real environment variables take precedence over anything set here.
# Never commit your real .env — it's already in .gitignore.

# Required: your DeepSeek API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: default model. One of: deepseek-v4-flash (default), deepseek-v4-pro
DEVBOT_MODEL=deepseek-v4-flash
