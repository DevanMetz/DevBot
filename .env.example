# DevBot configuration — copy this file to ".env" and fill in your values.
#   cp .env.example .env        (bash)
#   Copy-Item .env.example .env (PowerShell)
#
# Real environment variables take precedence over anything set here.
# Never commit your real .env — it's already in .gitignore.

# Required: your DeepSeek API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: default model. One of: deepseek-v4-flash (default), deepseek-v4-pro
DEVBOT_MODEL=deepseek-v4-flash

# Optional: local VibeThinker through llama.cpp/OpenAI-compatible server.
# To use it, start the server and set:
# DEVBOT_PROVIDER=local-vibethinker
# LOCAL_LLM_BASE_URL=http://127.0.0.1:8092/v1
# LOCAL_LLM_MODEL=vibethinker-q4-vulkan
# LOCAL_LLM_API_KEY=local
# LOCAL_LLM_MAX_TOKENS=600

# Optional: long-run token efficiency knobs.
# DEVBOT_VERBOSITY=concise
# DEVBOT_MAX_TOOL_OUTPUT=12000
# DEVBOT_READ_FILE_LIMIT=800
# DEVBOT_DIFF_CLIP=1200
# DEVBOT_SPECIALIST_RESULT_LIMIT=4000
